@PACKAGE_INIT@

if(NOT TARGET Nauty::Nauty)
    add_library(Nauty::Nauty STATIC IMPORTED)
    set_target_properties(Nauty::Nauty PROPERTIES
        IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/libnauty.a"
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
endif()
